# --- Campaign Concept Studio -------------------------------------------
# Copy this file to .env.local and fill in your key.
# .env.local is gitignored; never commit real keys.

# Required: your OpenAI API key (https://platform.openai.com/api-keys).
# Read only on the server — it is never sent to the browser.
OPENAI_API_KEY=sk-proj-...

# Optional: run the full UI without a key or spend.
# Serves canned concepts and SVG placeholder artwork with realistic delays.
# MOCK_AI=1
